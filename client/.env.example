SERVER_URL=http://127.0.0.1:5001
DISCORD_TOKEN=your_discord_token_here
DISCORD_ID=your_discord_id_here
DISCORD_USERNAME=your_discord_username_here
SAVE_PATH=

# AI Voice Dispatch Assistant
# Get your OpenAI API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get your Anthropic API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Voice input mode: PUSH_TO_TALK (default) or WAKE_WORD
VOICE_MODE=PUSH_TO_TALK

# Push-to-talk hotkey (default: F9)
PTT_KEY=F9

# Wake word (Picovoice Porcupine — get free key at https://console.picovoice.ai/)
# Built-in keywords: porcupine, bumblebee, hey barista, hey google, hey siri, picovoice, jarvis
# For a custom "Hey Dispatch" wake word: train at console.picovoice.ai and set WAKE_WORD_KEYWORD_PATH
PICOVOICE_ACCESS_KEY=
WAKE_WORD_KEYWORD_PATH=
