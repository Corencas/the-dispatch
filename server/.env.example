# ── Database ──────────────────────────────────────────────────────
# Railway sets this automatically when you add a PostgreSQL plugin.
# Locally, leave as-is to use SQLite.
DATABASE_URL=sqlite:///dispatch.db

# ── Flask ─────────────────────────────────────────────────────────
# Generate a real secret for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_real_secret

# ── Discord OAuth ─────────────────────────────────────────────────
# From https://discord.com/developers/applications → your app → OAuth2
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
# Must match exactly what's set in Discord's Redirects list.
# Local:      http://localhost:5001/auth/callback
# Production: https://your-app.railway.app/auth/callback
DISCORD_REDIRECT_URI=http://localhost:5001/auth/callback
